{%- comment -%}
  Quote Cart — non-floating navbar link
  Optional snippet for merchants who'd rather show the quote in their header
  than rely solely on the floating launcher.

  Paste in your theme's header.liquid or header section template:

      {% render 'quote-cart-navlink' %}

  The badge updates automatically via the same `quote:updated` event the
  floating launcher listens to.
{%- endcomment -%}

<a
  href="/apps/quote"
  class="qc-navlink"
  aria-label="{{ 'drawer.your_quote' | t }}"
  data-quote-cart-navlink
>
  <span class="qc-navlink-icon" aria-hidden="true">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
      <polyline points="14 2 14 8 20 8"></polyline>
      <line x1="9" y1="13" x2="15" y2="13"></line>
      <line x1="9" y1="17" x2="13" y2="17"></line>
    </svg>
  </span>
  <span class="qc-navlink-label">{{ 'drawer.your_quote' | t }}</span>
  <span class="qc-navlink-count" data-quote-cart-count>0</span>
</a>

<style>
  .qc-navlink {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 8px;
    color: inherit;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.2;
  }
  .qc-navlink:hover { background: rgba(0,0,0,0.04); }
  .qc-navlink-count {
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    border-radius: 10px;
    background: #d72c0d;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    line-height: 20px;
    text-align: center;
  }
  .qc-navlink-count[data-empty="true"] { display: none; }
</style>

<script>
  (function () {
    function render() {
      try {
        var raw = localStorage.getItem("quote_cart");
        var items = raw ? JSON.parse(raw) : [];
        if (!Array.isArray(items)) items = [];
        var count = items.reduce(function (s, i) {
          return s + (parseInt(i.quantity, 10) || 0);
        }, 0);
        document.querySelectorAll("[data-quote-cart-count]").forEach(function (el) {
          el.textContent = String(count);
          el.setAttribute("data-empty", count === 0 ? "true" : "false");
        });
      } catch (_) {}
    }
    render();
    window.addEventListener("quote:updated", render);
    window.addEventListener("storage", function (e) {
      if (e.key === "quote_cart") render();
    });
  })();
</script>
