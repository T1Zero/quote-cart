# ----- Shopify -----
# Created via `shopify app config link` and `shopify app dev`. Filled in by the CLI.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SCOPES=read_products,write_products,write_draft_orders,read_customers,write_customers

# ----- Database -----
# SQLite for local dev. Swap to a Postgres URL for production:
#   DATABASE_URL="postgresql://user:pass@host:5432/quote_cart"
DATABASE_URL="file:./dev.sqlite"

# ----- Encryption -----
# 32-byte key (base64). Used to encrypt SMTP password, Meta CAPI token, GA4 API secret at rest.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# ----- App proxy -----
# Set to your store's public domain (e.g., example.myshopify.com) when you want absolute URLs in emails.
# Optional: falls back to the request host.
PUBLIC_APP_URL=
